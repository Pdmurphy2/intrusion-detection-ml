{
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/.mypy_cache/**": true,
    "**/.pytest_cache/**": true,
    "**/__pycache__/**": true,
    "**/.ipynb_checkpoints/**": true,
    "**/data/**": true,
    "**/datasets/**": true,
    "**/archive/**": true,
    "**/models/**": true,
    "**/outputs/**": true,
    "**/*.csv": true,
    "**/*.parquet": true,
    "**/*.pkl": true,
    "**/*.joblib": true
  },
  "search.exclude": {
    "**/.venv/**": true,
    "**/venv/**": true,
    "**/__pycache__/**": true,
    "**/.ipynb_checkpoints/**": true,
    "**/data/**": true,
    "**/datasets/**": true,
    "**/archive/**": true,
    "**/models/**": true,
    "**/outputs/**": true,
    "**/*.csv": true,
    "**/*.parquet": true,
    "**/*.pkl": true,
    "**/*.joblib": true
  },
  "python.analysis.exclude": [
    "**/.venv",
    "**/venv",
    "**/data",
    "**/datasets",
    "**/archive",
    "**/models",
    "**/outputs",
    "**/__pycache__",
    "**/.ipynb_checkpoints"
  ],
  "python.analysis.indexing": false,
  "python.analysis.diagnosticMode": "openFilesOnly"
}